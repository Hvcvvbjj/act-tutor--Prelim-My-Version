# Optional judge-only technical view.
# In local development, SCOUT_JUDGE_PASSWORD may be used. In production, set
# SCOUT_JUDGE_PASSWORD_HASH instead (pbkdf2-sha256:iterations:salt:digest).
SCOUT_JUDGE_USERNAME=scout-judge
SCOUT_JUDGE_PASSWORD=
SCOUT_JUDGE_PASSWORD_HASH=

# For local end-to-end tests, put SCOUT_E2E_JUDGE_PASSWORD in the ignored
# .env.e2e.local file. Do not add that readable password to production settings.
