# Optional live lesson generation through any OpenAI-compatible chat endpoint.
# Without these values, Scout uses the reviewed personalized fallback.

# Local Ollama example:
AI_TUTOR_BASE_URL=http://127.0.0.1:11434/v1
AI_TUTOR_MODEL=qwen3:4b
AI_TUTOR_API_KEY=

# Optional session storage overrides:
# DIAGNOSTIC_SESSION_STORE_PATH=C:\absolute\path\diagnostic-sessions.json
# LEARNING_SESSION_STORE_PATH=C:\absolute\path\learning-sessions.json
